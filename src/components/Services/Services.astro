---
import "./Services.scss";

import Image from "astro/components/Image.astro";

import pinturas from "../../assets/services/pinturas.jpg";
import tanques from "../../assets/services/tanques.jpg";
import herramientas from "../../assets/services/herramientas.jpg";
import herramientaselectricas from "../../assets/services/herramientaselectricas.jpg";
import general from "../../assets/services/construccion.jpg";
import plomeria from "../../assets/services/plomeria.jpg";
import electricidad from "../../assets/services/electricidad.jpg";
import mallas from "../../assets/services/mallas.jpg";
import repuestosherramientas from "../../assets/services/repuestosherramientas.jpg";
import lumineria from "../../assets/services/lumineria.jpg";

const services = [
  { title: "Ferreteria en general", image: general },
  { title: "Herramientas manuales", image: herramientas },
  { title: "Herramientas eléctricas", image: herramientaselectricas },
  { title: "Repuestos para herramientas", image: repuestosherramientas },
  { title: "Electricidad", image: electricidad },
  { title: "Luminaria", image: lumineria },
  { title: "Plomería", image: plomeria },
  { title: "Pinturas", image: pinturas },
  { title: "Tanques de agua", image: tanques },
  { title: "Mallas", image: mallas },
];
---

<section id="services">
  <div class="services-content">
    <div class="services-left">
      <h2>Amplia variedad de productos para cada necesidad.</h2>
      <a href="#contact" class="btn-primary">OBTENER UNA COTIZACIÓN</a>
    </div>
    <div class="services-right">
      <div class="services-grid swiper">
        <div class="swiper-wrapper">
          {
            services.map((service) => (
              <div class="swiper-slide">
                <div class="service-card">
                  <div class="service-image">
                    <Image src={service.image} alt={service.title} />
                  </div>
                  <h3>{service.title}</h3>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <button class="arrow-prev" aria-label="Previous service">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
      </button>
      <button class="arrow-next" aria-label="Next service">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";
  import "swiper/css";

  document.addEventListener("DOMContentLoaded", () => {
    new Swiper(".services-grid", {
      modules: [Navigation],
      slidesPerView: "auto",
      spaceBetween: 20,
      loop: false,
      navigation: {
        nextEl: ".arrow-next",
        prevEl: ".arrow-prev",
        disabledClass: "swiper-button-disabled",
      },
      breakpoints: {
        768: {
          slidesPerView: "auto",
          spaceBetween: 20,
        },
      },
    });
  });
</script>
