---
import Map from "../Map/Map.astro";
import "./Contact.scss";
---

<section id="contact">
  <div class="contact-container">
    <div class="contact-header">
      <h2>Contacta a la ferretería líder en Coro, Falcón</h2>
      <p class="contact-subtitle">
        Estamos en Av. Independencia 204, Coro. Llámanos o escríbenos y te asesoramos sin costo.
      </p>
      <a href="tel:+582682531044" class="btn-primary">LLAMAR AHORA</a>
    </div>

    <div class="contact-grid">
      <div class="contact-card">
        <div class="card-icon">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 8L10.89 13.26C11.2187 13.4793 11.6049 13.5963 12 13.5963C12.3951 13.5963 12.7813 13.4793 13.11 13.26L21 8M5 19H19C19.5304 19 20.0391 18.7893 20.4142 18.4142C20.7893 18.0391 21 17.5304 21 17V7C21 6.46957 20.7893 5.96086 20.4142 5.58579C20.0391 5.21071 19.5304 5 19 5H5C4.46957 5 3.96086 5.21071 3.58579 5.58579C3.21071 5.96086 3 6.46957 3 7V17C3 17.5304 3.21071 18.0391 3.58579 18.4142C3.96086 18.7893 4.46957 19 5 19Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3>Email de contacto</h3>
        <p>
          Escríbenos para consultas, cotizaciones o cualquier información que necesites sobre
          nuestros productos.
        </p>
        <a href="mailto:info@febasa.com">info@febasa.com</a>
      </div>

      <div class="contact-card">
        <div class="card-icon">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 5C3 3.89543 3.89543 3 5 3H8.27924C8.70967 3 9.09181 3.27543 9.22792 3.68377L10.7257 8.17721C10.8831 8.64932 10.6694 9.16531 10.2243 9.38787L7.96701 10.5165C9.06925 12.9612 11.0388 14.9308 13.4835 16.033L14.6121 13.7757C14.8347 13.3306 15.3507 13.1169 15.8228 13.2743L20.3162 14.7721C20.7246 14.9082 21 15.2903 21 15.7208V19C21 20.1046 20.1046 21 19 21H18C9.71573 21 3 14.2843 3 6V5Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3>Teléfono</h3>
        <p>
          Llámanos para atención inmediata, asesoramiento personalizado o coordinar entregas a
          domicilio.
        </p>
        <a href="tel:+582682531044">+58 268 253 1044</a>
      </div>

      <div class="contact-card">
        <div class="card-icon">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M17.657 16.657L13.414 20.9C13.039 21.2746 12.5306 21.485 12.0005 21.485C11.4704 21.485 10.962 21.2746 10.587 20.9L6.343 16.657C5.22422 15.5381 4.46234 14.1127 4.15369 12.5608C3.84504 11.009 4.00349 9.40047 4.60901 7.93868C5.21452 6.4769 6.2399 5.22749 7.55548 4.34846C8.87107 3.46943 10.4178 3.00024 12 3.00024C13.5822 3.00024 15.1289 3.46943 16.4445 4.34846C17.7601 5.22749 18.7855 6.4769 19.391 7.93868C19.9965 9.40047 20.155 11.009 19.8463 12.5608C19.5377 14.1127 18.7758 15.5381 17.657 16.657Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M12 13C13.1046 13 14 12.1046 14 11C14 9.89543 13.1046 9 12 9C10.8954 9 10 9.89543 10 11C10 12.1046 10.8954 13 12 13Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3>Nuestra ubicación</h3>
        <p>
          Visítanos en nuestra sucursal para ver nuestros productos y recibir asesoramiento de
          expertos.
        </p>
        <a href="https://maps.google.com" target="_blank">Av. Independencia 204, Coro, Falcón</a>
      </div>

      <div class="contact-card schedule-card">
        <div class="card-icon">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 8V12L15 15M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3>Horarios de atención</h3>
        <p>
          Estamos disponibles para atenderte en los siguientes horarios. También ofrecemos asesoría
          telefónica.
        </p>
        <p class="schedule">
          <strong>Lunes a Viernes:</strong> 8:00am - 1:00pm y 2:00pm - 5:00pm
        </p>
      </div>

      <div class="contact-card social-card">
        <div class="card-icon">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M17 2H7C4.23858 2 2 4.23858 2 7V17C2 19.7614 4.23858 22 7 22H17C19.7614 22 22 19.7614 22 17V7C22 4.23858 19.7614 2 17 2Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M16 11.37C16.1234 12.2022 15.9813 13.0522 15.5938 13.799C15.2063 14.5458 14.5932 15.1514 13.8416 15.5297C13.0901 15.9079 12.2384 16.0396 11.4078 15.9059C10.5771 15.7723 9.80976 15.3801 9.21484 14.7852C8.61992 14.1902 8.22773 13.4229 8.09407 12.5922C7.9604 11.7616 8.09207 10.9099 8.47033 10.1584C8.84859 9.40685 9.45419 8.79374 10.201 8.40624C10.9478 8.01874 11.7978 7.87658 12.63 8C13.4789 8.12588 14.2649 8.52146 14.8717 9.1283C15.4785 9.73515 15.8741 10.5211 16 11.37Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M17.5 6.5H17.51"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3>Redes sociales</h3>
        <p>
          Síguenos en nuestras redes sociales para estar al tanto de promociones, novedades y
          consejos sobre nuestros productos.
        </p>
        <div class="social-links">
          <a href="https://facebook.com" target="_blank" class="social-link">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M18 2H15C13.6739 2 12.4021 2.52678 11.4645 3.46447C10.5268 4.40215 10 5.67392 10 7V10H7V14H10V22H14V14H17L18 10H14V7C14 6.73478 14.1054 6.48043 14.2929 6.29289C14.4804 6.10536 14.7348 6 15 6H18V2Z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Facebook
          </a>
          <a href="https://instagram.com" target="_blank" class="social-link">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17 2H7C4.23858 2 2 4.23858 2 7V17C2 19.7614 4.23858 22 7 22H17C19.7614 22 22 19.7614 22 17V7C22 4.23858 19.7614 2 17 2Z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M16 11.37C16.1234 12.2022 15.9813 13.0522 15.5938 13.799C15.2063 14.5458 14.5932 15.1514 13.8416 15.5297C13.0901 15.9079 12.2384 16.0396 11.4078 15.9059C10.5771 15.7723 9.80976 15.3801 9.21484 14.7852C8.61992 14.1902 8.22773 13.4229 8.09407 12.5922C7.9604 11.7616 8.09207 10.9099 8.47033 10.1584C8.84859 9.40685 9.45419 8.79374 10.201 8.40624C10.9478 8.01874 11.7978 7.87658 12.63 8C13.4789 8.12588 14.2649 8.52146 14.8717 9.1283C15.4785 9.73515 15.8741 10.5211 16 11.37Z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Instagram
          </a>
          <a href="https://wa.me/582682531044" target="_blank" class="social-link">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M21 11.5C21.0034 13.1171 20.6063 14.7103 19.8431 16.1431C19.0798 17.5759 17.973 18.8028 16.6187 19.7194C15.2645 20.636 13.7043 21.2153 12.0806 21.407C10.4569 21.5988 8.81481 21.3973 7.29 20.82L3 22L4.18 17.71C3.52393 16.0264 3.32099 14.1988 3.59095 12.4114C3.86091 10.6239 4.59311 8.94209 5.72046 7.54773C6.84781 6.15337 8.33163 5.09731 10.0201 4.49152C11.7086 3.88573 13.5327 3.75419 15.29 4.11L15.5 4.15C17.8381 4.65649 19.9452 5.90447 21.4954 7.69448C23.0456 9.48449 23.9518 11.7182 24.08 14.05L24.08 14.5C24.08 14.5 21 11.5 21 11.5Z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

      <div class="contact-card map-card">
        <Map />
      </div>

      <div class="contact-card form-card">
        <h3>Envíanos un mensaje</h3>
        <form class="contact-form">
          <div class="form-group">
            <input type="text" id="name" name="name" placeholder="Nombre completo" required />
          </div>

          <div class="form-group">
            <input type="email" id="email" name="email" placeholder="Email" required />
          </div>

          <div class="form-group">
            <input type="tel" id="phone" name="phone" placeholder="Teléfono" />
          </div>

          <div class="form-group">
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Cuéntanos sobre tu proyecto..."
              required></textarea>
          </div>

          <button type="submit" class="btn-submit">ENVIAR MENSAJE</button>
        </form>
      </div>
    </div>
  </div>
</section>
