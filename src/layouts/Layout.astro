---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ferretería Batista | Materiales de Construcción en Coro, Falcón",
  description = "Ferretería Batista (Febasa) — más de 50 años distribuyendo materiales de construcción, herramientas, plomería, electricidad y pintura en Coro, Falcón, Venezuela. Llámanos: +58 268 253 1044.",
} = Astro.props;

const siteUrl = "https://febasa.com";
const ogImage = `${siteUrl}/og-image.jpg`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HardwareStore",
  "name": "Ferretería Batista",
  "alternateName": "Febasa",
  "description": "Ferretería en Coro, Falcón con más de 50 años de experiencia. Materiales de construcción, herramientas, plomería, electricidad, pintura y más.",
  "url": siteUrl,
  "telephone": "+582682531044",
  "email": "info@febasa.com",
  "foundingDate": "1970",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Independencia 204",
    "addressLocality": "Coro",
    "addressRegion": "Falcón",
    "addressCountry": "VE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 11.4053,
    "longitude": -69.6717
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "13:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "14:00",
      "closes": "17:00"
    }
  ],
  "hasMap": "https://maps.google.com/?q=Av.+Independencia+204,+Coro,+Falcón",
  "currenciesAccepted": "VES",
  "paymentAccepted": "Efectivo, Transferencia",
  "areaServed": {
    "@type": "City",
    "name": "Coro",
    "containedInPlace": {
      "@type": "State",
      "name": "Falcón"
    }
  }
};
